#include <stdio.h>
#include <conio.h>

void main()
{
    int a, b, c, d;     // Input variables
    int t1, t2, t3;     // Temporary variables for optimization
    int x, y;           // Variables for strength reduction

    clrscr();           // Clears output screen (Turbo C)

    /* INPUT SECTION */
    printf("Enter values of a, b, c, d: ");
    scanf("%d %d %d %d", &a, &b, &c, &d);

    printf("\n----- BEFORE OPTIMIZATION (Common Sub-expression) -----\n");

    /* BEFORE CSE:
       (a + b) is calculated twice → redundant computation */
    t1 = (a + b) * c;
    t2 = (a + b) * d;

    printf("t1 = %d\n", t1);
    printf("t2 = %d\n", t2);

    printf("\n----- AFTER COMMON SUB-EXPRESSION ELIMINATION -----\n");

    /* AFTER CSE:
       (a + b) is calculated once and reused */
    t3 = (a + b);   // store common expression

    t1 = t3 * c;    // reuse result
    t2 = t3 * d;

    printf("t1 = %d\n", t1);
    printf("t2 = %d\n", t2);

    printf("\n----- STRENGTH REDUCTION -----\n");

    /* INPUT for strength reduction */
    printf("Enter value of x: ");
    scanf("%d", &x);

    /* BEFORE STRENGTH REDUCTION:
       multiplication is used (costly operation) */
    y = x * 2;
    printf("Before Strength Reduction y = %d\n", y);

    /* AFTER STRENGTH REDUCTION:
       multiplication replaced with addition (faster operation) */
    y = x + x;

    printf("After Strength Reduction y = %d\n", y);

    getch();   // Waits for key press (Turbo C)
}





