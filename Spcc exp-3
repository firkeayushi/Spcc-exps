#include<stdio.h>      // Input-output
#include<conio.h>      // clrscr(), getch()
#include<stdlib.h>     // malloc()
#include<string.h>     // string functions

/* Global counters */
int MDTC = 1;
int MNTC = 1;
int ALA_INDEX = 1;

/* ALA structure (Argument List Array) */
struct ALA {
    int index;
    char arg[20];
    struct ALA *next;
};

/* MDT structure */
struct MDT {
    int index;
    char instruction[100];
    struct MDT *next;
};

/* MNT structure */
struct MNT {
    int index;
    char name[20];
    struct MDT *mdtPtr;
    struct MNT *next;
};

/* Head pointers */
struct ALA *alaHead = NULL;
struct MDT *mdtHead = NULL;
struct MNT *mntHead = NULL;

/* Find macro in MNT */
struct MDT* findMacro(char *name)
{
    struct MNT *temp;
    temp = mntHead;

    while(temp != NULL)
    {
        if(strcmp(temp->name, name) == 0)
            return temp->mdtPtr;
        temp = temp->next;
    }
    return NULL;
}

/* PASS 1 */
void pass1(FILE *fp)
{
    char line[100];
    char name[20];
    char arg[20];

    struct MDT *mdtTemp;
    struct MDT *mdtNode;
    struct MDT *newNode;
    struct MDT *endNode;

    struct MNT *mntNode;
    struct ALA *alaNode;

    while(fgets(line, sizeof(line), fp) != NULL)
    {
        /* Detect MACRO */
        if(strncmp(line, "MACRO", 5) == 0)
        {
            printf("\nMACRO ");

            fgets(line, sizeof(line), fp);
            sscanf(line, "%s %s", name, arg);

            printf("%s Detected...\n", name);

            /* MNT entry */
            mntNode = (struct MNT*)malloc(sizeof(struct MNT));
            mntNode->index = MNTC++;
            strcpy(mntNode->name, name);
            mntNode->next = mntHead;
            mntHead = mntNode;

            printf("\n%s added into Name Table", name);

            /* ALA entry */
            alaNode = (struct ALA*)malloc(sizeof(struct ALA));
            alaNode->index = ALA_INDEX++;
            strcpy(alaNode->arg, arg);
            alaNode->next = alaHead;
            alaHead = alaNode;

            printf("\nArgument %s added into ALA", arg);

            /* MDT header */
            mdtNode = (struct MDT*)malloc(sizeof(struct MDT));
            mdtNode->index = MDTC++;
            strcpy(mdtNode->instruction, name);
            mdtNode->next = NULL;

            mdtHead = mdtNode;
            mdtTemp = mdtNode;
            mntNode->mdtPtr = mdtNode;

            printf("\nDefinition Table entry created for %s", name);

            /* Macro body */
            while(fgets(line, sizeof(line), fp) != NULL)
            {
                if(strncmp(line, "MEND", 4) == 0)
                {
                    endNode = (struct MDT*)malloc(sizeof(struct MDT));
                    endNode->index = MDTC++;
                    strcpy(endNode->instruction, "MEND");
                    endNode->next = NULL;

                    mdtTemp->next = endNode;
                    mdtTemp = endNode;

                    printf("\nMEND added at index %d", endNode->index);
                    break;
                }

                newNode = (struct MDT*)malloc(sizeof(struct MDT));
                newNode->index = MDTC++;

                strcpy(newNode->instruction, line);

                newNode->next = NULL;
                mdtTemp->next = newNode;
                mdtTemp = newNode;

                printf("\nEntry appended for %s at index %d",
                       newNode->instruction, newNode->index);
            }
        }
    }

    printf("\n\nAll tables updated. Pass 1 Complete!\n");
}

