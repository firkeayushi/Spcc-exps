Addition & Subtraction:-
%option noyywrap
%{
    #include <stdio.h>
    #include <conio.h> 
    int a = 10;
    int b = 5;
%}

%%
[0-9]
[a-z]
.
%%

int main()
{   
    // 1. Addition
    int sum = a + b;
    printf("Addition: %d + %d = %d\n", a, b, sum);

    // 2. Subtraction
    int diff = a - b;
    printf("Subtraction: %d - %d = %d\n", a, b, diff);

    getch(); 
    
    return 0;
}





Even or Odd:-
%option noyywrap
%{
#include<stdio.h>
#include<conio.h>

int num;
%}

%%
[0-9]
[a-z]
.
%%

int main()
{
    printf("Enter a number: ");
    scanf("%d",&num);

    if(num % 2 == 0)
        printf("%d is Even", num);
    else
        printf("%d is Odd", num);

    getch();

    return 0;
}
